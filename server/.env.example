# Example environment variables for SplitWise-VN server
# Copy to `.env` and fill in real values (do NOT commit `.env` to git)

# Server
PORT=3000
NODE_ENV=development

# JWT secrets
ACCESSTOKEN_KEY=your_access_token_secret_here
REFRESHTOKEN_KEY=your_refresh_token_secret_here

# Twilio (for sending OTPs)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Notes:
# - Keep secrets secure (use environment variables in production or secret store)
# - If you deploy to a platform (Heroku, Vercel, Azure, etc.), set these vars in the platform's settings
