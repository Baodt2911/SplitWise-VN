// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum NotificationType {
  // Expense
  EXPENSE_ADDED        @map("expense_added")
  EXPENSE_UPDATED      @map("expense_updated")
  EXPENSE_DELETED      @map("expense_deleted")

  // Payment
  PAYMENT_REQUEST      @map("payment_request")      // A báo đã thanh toán → gửi B xác nhận
  PAYMENT_CONFIRMED    @map("payment_confirmed")    // B xác nhận đã nhận tiền
  PAYMENT_REJECTED     @map("payment_rejected")     // B từ chối

  // Member
  MEMBER_ADDED         @map("member_added")
  MEMBER_REMOVED       @map("member_removed")
  MEMBER_LEFT          @map("member_left")
  MEMBER_ROLE_CHANGED  @map("member_role_changed")
  MEMBER_SELF_JOINED   @map("member_self_joined")    // user tự join group

  // Comment
  COMMENT_ADDED        @map("comment_added")
  COMMENT_MENTION      @map("comment_mention")

  // Other
  REMINDER             @map("reminder")
}


enum RelatedType {
  EXPENSE     @map("expense")
  SETTLEMENT  @map("settlement")
  GROUP       @map("group")
  USER        @map("user")
  COMMENT     @map("comment")
}

enum ActivityAction {
  // Group
  CREATE_GROUP        @map("create_group")
  UPDATE_GROUP        @map("update_group")
  DELETE_GROUP        @map("delete_group")

  ADD_MEMBER          @map("add_member")
  REMOVE_MEMBER       @map("remove_member")
  MEMBER_LEFT         @map("member_left")
  CHANGE_MEMBER_ROLE  @map("change_member_role")
  SELF_JOIN_GROUP      @map("self_join_group")       // tự join

  // Expense
  ADD_EXPENSE         @map("add_expense")
  UPDATE_EXPENSE      @map("update_expense")
  DELETE_EXPENSE      @map("delete_expense")

  // Payment workflow
  CREATE_PAYMENT      @map("create_payment")        // A tạo payment → chờ xác nhận
  CONFIRM_PAYMENT     @map("confirm_payment")       // B xác nhận đã nhận
  REJECT_PAYMENT      @map("reject_payment")        // B từ chối

  // Comment
  ADD_COMMENT         @map("add_comment")
  DELETE_COMMENT      @map("delete_comment")

  // Other
  REMINDER_TRIGGERED  @map("reminder_triggered")
}


// ============================================
// MODELS
// ============================================

model User {
  id                String  @id @default(uuid())
  phone             String  @unique @db.VarChar(15)
  email             String? @unique @db.VarChar(255)
  passwordHash      String  @map("password_hash") @db.VarChar(255)
  fullName          String  @map("full_name") @db.VarChar(100)
  avatarUrl         String? @map("avatar_url") @db.Text
  googleId          String? @unique @map("google_id") @db.VarChar(255)
  // Thông tin ngân hàng
  bankName          String? @map("bank_name") @db.VarChar(100)
  bankAccountNumber String? @map("bank_account_number") @db.VarChar(50)
  bankAccountName   String? @map("bank_account_name") @db.VarChar(100)

  // Cài đặt
  language       String  @default("vi") @db.VarChar(10)
  timezone       String  @default("Asia/Ho_Chi_Minh") @db.VarChar(50)
  currency       String  @default("VND") @db.VarChar(3)
  allowDirectAdd Boolean @default(false) @map("allow_direct_add")

  // Premium
  isPremium        Boolean   @default(false) @map("is_premium")
  premiumExpiresAt DateTime? @map("premium_expires_at") @db.Timestamp()

  // Bảo mật
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret  String? @map("two_factor_secret") @db.VarChar(255)

  // Metadata
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamp()
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamp()
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamp()

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp()
  deletedAt DateTime? @map("deleted_at") @db.Timestamp()

  // Relations
  groupsCreated        Group[]               @relation("GroupCreator")
  groupMemberships     GroupMember[]
  expensesPaid         Expense[]             @relation("ExpensePaidBy")
  expensesCreated      Expense[]             @relation("ExpenseCreator")
  expenseSplits        ExpenseSplit[]
  settlementsPaid      Settlement[]          @relation("SettlementPayer")
  settlementsReceived  Settlement[]          @relation("SettlementPayee")
  settlementsConfirmed Settlement[]          @relation("SettlementConfirmer")
  friendshipsInitiated Friendship[]          @relation("FriendshipUser")
  friendshipsReceived  Friendship[]          @relation("FriendshipFriend")
  notifications        Notification[]
  comments             Comment[]
  activities           Activity[]
  groupInvitesSent     GroupInvite[]         @relation("InviteSender")
  groupInvitesUsed     GroupInvite[]         @relation("InviteUser")
  premiumSubscriptions PremiumSubscription[]
  referralsGiven       Referral[]            @relation("Referrer")
  referralsReceived    Referral[]            @relation("Referred")
  pointTransactions    UserPoint[]
  settings             UserSettings?

  @@index([phone, deletedAt])
  @@index([email, deletedAt])
  @@index([isPremium, premiumExpiresAt])
  @@map("users")
}

model Group {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(255)
  description String? @db.Text
  avatarUrl   String? @map("avatar_url") @db.Text

  // Quyền riêng tư
  isPublic   Boolean @default(false) @map("is_public")
  inviteCode String? @unique @map("invite_code") @db.VarChar(50)

  // Settings
  allowMemberEdit            Boolean @default(false) @map("allow_member_edit")
  allowMemberDirectAdd       Boolean @default(false) @map("allow_member_direct_add")
  requirePaymentConfirmation Boolean @default(true) @map("require_payment_confirmation")
  autoReminderEnabled        Boolean @default(true) @map("auto_reminder_enabled")
  reminderDays               Int     @default(3) @map("reminder_days")

  // Metadata
  createdBy  String?   @map("created_by")
  archivedAt DateTime? @map("archived_at") @db.Timestamp()

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp()
  deletedAt DateTime? @map("deleted_at") @db.Timestamp()

  // Relations
  creator     User?         @relation("GroupCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  invites     GroupInvite[]
  activities  Activity[]

  @@index([createdBy, deletedAt])
  @@index([inviteCode, deletedAt])
  @@index([archivedAt, deletedAt])
  @@map("groups")
}

model GroupMember {
  id      String @id @default(uuid())
  groupId String @map("group_id")
  userId  String @map("user_id")

  // Role
  role String @default("member") @db.VarChar(20) // 'admin', 'member'

  // Status
  status String @default("active") @db.VarChar(20) // 'active', 'left', 'removed'

  // Metadata
  joinedAt DateTime  @default(now()) @map("joined_at") @db.Timestamp()
  leftAt   DateTime? @map("left_at") @db.Timestamp()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, status])
  @@index([userId, status])
  @@index([groupId, role])
  @@map("group_members")
}

model Expense {
  id      String @id @default(uuid())
  groupId String @map("group_id")

  // Thông tin chi phí
  description String  @db.VarChar(500)
  amount      Decimal @db.Decimal(15, 2)
  currency    String  @default("VND") @db.VarChar(3)

  // Người trả
  paidBy String @map("paid_by")

  // Phân loại
  category String @default("other") @db.VarChar(50) // food, transport, entertainment, accommodation, shopping, other

  // Ngày chi
  expenseDate DateTime @default(now()) @map("expense_date") @db.Date

  // Hóa đơn
  receiptUrl String? @map("receipt_url") @db.Text

  // Ghi chú
  notes String? @db.Text

  // Cách chia
  splitType String @default("equal") @map("split_type") @db.VarChar(20) // equal, exact, percentage, shares

  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp()
  deletedAt DateTime? @map("deleted_at") @db.Timestamp()

  // Relations
  group      Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidByUser User           @relation("ExpensePaidBy", fields: [paidBy], references: [id], onDelete: Cascade)
  creator    User           @relation("ExpenseCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  splits     ExpenseSplit[]
  comments   Comment[]

  @@index([groupId, expenseDate(sort: Desc), deletedAt])
  @@index([paidBy, deletedAt])
  @@index([category, deletedAt])
  @@index([expenseDate(sort: Desc), deletedAt])
  @@map("expenses")
}

model ExpenseSplit {
  id        String @id @default(uuid())
  expenseId String @map("expense_id")
  userId    String @map("user_id")

  // Số tiền phải trả
  amount Decimal @db.Decimal(15, 2)

  // Phần chia (dùng cho split_type = 'shares')
  shares Decimal? @db.Decimal(10, 2)

  // Phần trăm (dùng cho split_type = 'percentage')
  percentage Decimal? @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
  @@map("expense_splits")
}

model Settlement {
  id      String @id @default(uuid())
  groupId String @map("group_id")

  // Người trả
  payerId String @map("payer_id")

  // Người nhận
  payeeId String @map("payee_id")

  // Số tiền
  amount   Decimal @db.Decimal(15, 2)
  currency String  @default("VND") @db.VarChar(3)

  // Trạng thái
  status String @default("pending") @db.VarChar(20) // pending, confirmed, rejected

  // Ngày thanh toán
  paymentDate DateTime @default(now()) @map("payment_date") @db.Date

  // Phương thức
  paymentMethod String? @map("payment_method") @db.VarChar(50) // cash, bank_transfer, momo, zalopay, vnpay

  // Ghi chú
  notes String? @db.Text

  // Xác nhận
  confirmedBy String?   @map("confirmed_by")
  confirmedAt DateTime? @map("confirmed_at") @db.Timestamp()

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp()
  deletedAt DateTime? @map("deleted_at") @db.Timestamp()

  // Relations
  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer     User  @relation("SettlementPayer", fields: [payerId], references: [id], onDelete: Cascade)
  payee     User  @relation("SettlementPayee", fields: [payeeId], references: [id], onDelete: Cascade)
  confirmer User? @relation("SettlementConfirmer", fields: [confirmedBy], references: [id])

  @@index([groupId, status, deletedAt])
  @@index([payerId, status, deletedAt])
  @@index([payeeId, status, deletedAt])
  @@index([status, deletedAt])
  @@map("settlements")
}

model Friendship {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  friendId String @map("friend_id")

  // Trạng thái
  status String @default("pending") @db.VarChar(20) // pending, accepted, blocked

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  user   User @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId, status])
  @@index([friendId, status])
  @@map("friendships")
}

model Notification {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Loại thông báo
  type NotificationType

  // Tiêu đề & nội dung
  title String @db.VarChar(255)
  body  String @db.Text

  // Liên kết đến
  relatedType RelatedType? @map("related_type") // expense, settlement, group, user
  relatedId   String? @map("related_id")

  // Trạng thái
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at") @db.Timestamp()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([type])
  @@index([relatedType, relatedId])
  @@map("notifications")
}

model Comment {
  id        String @id @default(uuid())
  expenseId String @map("expense_id")
  userId    String @map("user_id")

  // Nội dung
  content String @db.Text

  // Reply
  parentId String? @map("parent_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp()
  deletedAt DateTime? @map("deleted_at") @db.Timestamp()

  // Relations
  expense Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([expenseId, createdAt, deletedAt])
  @@index([userId, deletedAt])
  @@index([parentId, deletedAt])
  @@map("comments")
}

model Activity {
  id      String  @id @default(uuid())
  groupId String? @map("group_id")
  userId  String  @map("user_id")

  // Loại hoạt động
  action ActivityAction

  // Mô tả
  description String @db.Text

  // Metadata (JSON)
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("activities")
}

model GroupInvite {
  id      String @id @default(uuid())
  groupId String @map("group_id")

  // Người mời
  invitedBy String @map("invited_by")

  // Mã mời
  inviteToken String @unique @map("invite_token") @db.VarChar(100)

  // Thông tin
  email String? @db.VarChar(255)
  phone String? @db.VarChar(15)

  // Trạng thái
  status String @default("pending") @db.VarChar(20) // pending, accepted, expired

  // Hết hạn
  expiresAt DateTime @map("expires_at") @db.Timestamp()

  // Sử dụng
  usedBy String?   @map("used_by")
  usedAt DateTime? @map("used_at") @db.Timestamp()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter User  @relation("InviteSender", fields: [invitedBy], references: [id], onDelete: Cascade)
  user    User? @relation("InviteUser", fields: [usedBy], references: [id])

  @@index([inviteToken, status])
  @@index([groupId, status])
  @@index([expiresAt])
  @@map("group_invites")
}

model PremiumSubscription {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Gói
  plan String @db.VarChar(20) // monthly, yearly, lifetime

  // Giá
  amount   Decimal @db.Decimal(15, 2)
  currency String  @default("VND") @db.VarChar(3)

  // Thời gian
  startsAt  DateTime  @map("starts_at") @db.Timestamp()
  expiresAt DateTime? @map("expires_at") @db.Timestamp()

  // Trạng thái
  status String @default("active") @db.VarChar(20) // active, cancelled, expired

  // Tự động gia hạn
  autoRenew Boolean @default(true) @map("auto_renew")

  // Thanh toán
  paymentMethod String? @map("payment_method") @db.VarChar(50)
  transactionId String? @map("transaction_id") @db.VarChar(255)

  // Hủy
  cancelledAt  DateTime? @map("cancelled_at") @db.Timestamp()
  cancelReason String?   @map("cancel_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
  @@index([autoRenew, expiresAt, status])
  @@map("premium_subscriptions")
}

model Referral {
  id         String  @id @default(uuid())
  referrerId String  @map("referrer_id")
  referredId String? @map("referred_id")

  // Mã giới thiệu
  referralCode String @unique @map("referral_code") @db.VarChar(50)

  // Trạng thái
  status String @default("pending") @db.VarChar(20) // pending, completed, rewarded

  // Phần thưởng
  rewardType   String?   @map("reward_type") @db.VarChar(50) // premium_days, points
  rewardAmount Int?      @map("reward_amount")
  rewardedAt   DateTime? @map("rewarded_at") @db.Timestamp()

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp()
  completedAt DateTime? @map("completed_at") @db.Timestamp()

  // Relations
  referrer User  @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User? @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId, status])
  @@index([referralCode])
  @@map("referrals")
}

model UserPoint {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Điểm
  points Int

  // Loại giao dịch
  transactionType String @map("transaction_type") @db.VarChar(50) // earn, redeem

  // Nguồn
  source String @db.VarChar(50) // complete_profile, add_expense, referral, check_in, etc.

  // Mô tả
  description String? @db.Text

  // Liên kết
  relatedType String? @map("related_type") @db.VarChar(50)
  relatedId   String? @map("related_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([transactionType])
  @@map("user_points")
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  // Thông báo
  notificationExpenseAdded     Boolean @default(true) @map("notification_expense_added")
  notificationPaymentRequest   Boolean @default(true) @map("notification_payment_request")
  notificationPaymentConfirmed Boolean @default(true) @map("notification_payment_confirmed")
  notificationMemberAdded      Boolean @default(true) @map("notification_member_added")
  notificationComment          Boolean @default(true) @map("notification_comment")
  notificationReminder         Boolean @default(true) @map("notification_reminder")

  // Email
  emailNotifications Boolean @default(true) @map("email_notifications")
  emailWeeklySummary Boolean @default(false) @map("email_weekly_summary")

  // Push
  pushNotifications Boolean @default(true) @map("push_notifications")

  // App
  appLockEnabled   Boolean @default(false) @map("app_lock_enabled")
  appLockTimeout   Int     @default(5) @map("app_lock_timeout") // minutes
  biometricEnabled Boolean @default(false) @map("biometric_enabled")

  // Privacy
  showInSearch        Boolean @default(true) @map("show_in_search")
  allowFriendRequests Boolean @default(true) @map("allow_friend_requests")
  showOnlineStatus    Boolean @default(true) @map("show_online_status")

  // Theme
  theme       String @default("light") @db.VarChar(20) // light, dark, auto
  accentColor String @default("blue") @map("accent_color") @db.VarChar(20)
  fontSize    String @default("medium") @map("font_size") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}
